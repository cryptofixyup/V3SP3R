<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!--
      API keys live in EncryptedSharedPreferences (Android Keystore-backed).
      The Keystore key is device-bound and cannot be transferred, so the encrypted
      blob would be useless on a new device — exclude to avoid silent failures.
      DataStore and Room DB are also excluded: they may contain bridge URLs,
      conversation history, and audit logs that should not transfer automatically.
    -->
    <cloud-backup>
        <exclude domain="sharedpref" path="vesper_secure_prefs.xml"/>
        <exclude domain="file" path="datastore/vesper_settings.preferences_pb"/>
        <exclude domain="database" path="vesper_database"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="vesper_secure_prefs.xml"/>
        <exclude domain="file" path="datastore/vesper_settings.preferences_pb"/>
        <exclude domain="database" path="vesper_database"/>
    </device-transfer>
</data-extraction-rules>
